{
  "id": "iso27001",
  "name": "ISO/IEC 27001:2022 Annex A — Starter Pack",
  "version": "0.1.0",
  "framework": "ISO/IEC 27001:2022 (Annex A controls, ISO/IEC 27002:2022 guidance)",
  "controls": [
    {
      "id": "A.5.15",
      "name": "Access control",
      "hooks": ["egress-allowlist", "ip-guard"]
    },
    {
      "id": "A.5.23",
      "name": "Information security for use of cloud services",
      "hooks": ["egress-allowlist"]
    },
    {
      "id": "A.5.33",
      "name": "Protection of records",
      "hooks": ["audit-hashchain"]
    },
    {
      "id": "A.8.2",
      "name": "Privileged access rights",
      "hooks": ["pre-commit-scan", "secret-redaction"]
    },
    {
      "id": "A.8.12",
      "name": "Data leakage prevention",
      "hooks": ["ip-guard", "secret-redaction", "egress-allowlist"]
    },
    {
      "id": "A.8.15",
      "name": "Logging",
      "hooks": ["audit-hashchain"]
    },
    {
      "id": "A.8.28",
      "name": "Secure coding",
      "hooks": ["pre-commit-scan"]
    }
  ]
}
