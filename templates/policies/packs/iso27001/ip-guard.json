{
  "version": "0.1.0",
  "mode": "redact",
  "patterns": [
    {
      "id": "iso-private-key",
      "name": "PEM private key block",
      "regex": "-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----",
      "severity": "critical",
      "replacement": "[REDACTED:PRIVATE_KEY]"
    },
    {
      "id": "iso-cloud-key",
      "name": "Cloud provider access key",
      "regex": "(AKIA|ASIA)[0-9A-Z]{16}",
      "severity": "high",
      "replacement": "[REDACTED:CLOUD_KEY]"
    },
    {
      "id": "iso-generic-secret",
      "name": "Generic high-entropy secret assignment",
      "regex": "(?i)(api[_-]?key|secret|token|password)\\s*[:=]\\s*[\"']?[A-Za-z0-9+/=_\\-]{24,}[\"']?",
      "severity": "high",
      "replacement": "$1=[REDACTED]"
    },
    {
      "id": "iso-internal-host",
      "name": "Internal hostname (RFC 1918 / .internal)",
      "regex": "\\b((10|192\\.168|172\\.(1[6-9]|2[0-9]|3[0-1]))\\.[0-9.]+|[a-z0-9-]+\\.internal)\\b",
      "severity": "medium",
      "replacement": "[REDACTED:INTERNAL_HOST]"
    }
  ]
}
