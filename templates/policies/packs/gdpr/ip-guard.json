{
  "version": "0.1.0",
  "mode": "redact",
  "patterns": [
    {
      "id": "gdpr-email",
      "name": "Email address",
      "regex": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
      "severity": "high",
      "replacement": "[REDACTED:EMAIL]"
    },
    {
      "id": "gdpr-iban",
      "name": "IBAN (EU bank account)",
      "regex": "\\b[A-Z]{2}\\d{2}[A-Z0-9]{1,30}\\b",
      "severity": "high",
      "replacement": "[REDACTED:IBAN]"
    },
    {
      "id": "gdpr-uk-nino",
      "name": "UK National Insurance Number",
      "regex": "\\b[A-CEGHJ-PR-TW-Z]{2}\\d{6}[A-D]\\b",
      "severity": "high",
      "replacement": "[REDACTED:NINO]"
    },
    {
      "id": "gdpr-de-steueridnr",
      "name": "German Steuer-ID (11 digits)",
      "regex": "(?i)\\b(steuer[- ]?id|tax[- ]?id)\\s*[:=]?\\s*\\d{11}\\b",
      "severity": "high",
      "replacement": "[REDACTED:DE_TAX_ID]"
    },
    {
      "id": "gdpr-fr-insee",
      "name": "French INSEE / NIR (15 digits)",
      "regex": "(?i)\\b(insee|nir|s[ée]curit[ée][- ]?sociale)\\s*[:=]?\\s*[12]\\d{2}(0[1-9]|1[0-2])\\d{10}\\b",
      "severity": "high",
      "replacement": "[REDACTED:FR_NIR]"
    },
    {
      "id": "gdpr-passport",
      "name": "Passport number (heuristic)",
      "regex": "(?i)\\bpassport\\s*(no|number|#)?\\s*[:=]?\\s*[A-Z0-9]{6,9}\\b",
      "severity": "high",
      "replacement": "[REDACTED:PASSPORT]"
    },
    {
      "id": "gdpr-ip-address",
      "name": "IPv4 address (personal data under GDPR)",
      "regex": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
      "severity": "medium",
      "replacement": "[REDACTED:IP]"
    }
  ]
}
