{
  "version": "0.1.0",
  "mode": "block",
  "patterns": [
    {
      "id": "hipaa-ssn",
      "name": "U.S. Social Security Number",
      "regex": "\\b(?!000|666|9\\d{2})\\d{3}[- ]?(?!00)\\d{2}[- ]?(?!0000)\\d{4}\\b",
      "severity": "critical"
    },
    {
      "id": "hipaa-mrn",
      "name": "Medical Record Number (heuristic)",
      "regex": "(?i)\\b(MRN|medical[ _-]?record[ _-]?number)\\s*[:#=]?\\s*[A-Z0-9-]{6,12}\\b",
      "severity": "critical"
    },
    {
      "id": "hipaa-dob",
      "name": "Date of birth (DOB context)",
      "regex": "(?i)\\b(DOB|date[ _-]?of[ _-]?birth)\\s*[:=]?\\s*\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}\\b",
      "severity": "high"
    },
    {
      "id": "hipaa-icd10",
      "name": "ICD-10 diagnosis code",
      "regex": "\\b[A-TV-Z][0-9][0-9AB](\\.[0-9A-TV-Z]{1,4})?\\b",
      "severity": "medium"
    },
    {
      "id": "hipaa-npi",
      "name": "U.S. National Provider Identifier",
      "regex": "(?i)\\b(NPI)\\s*[:=]?\\s*\\d{10}\\b",
      "severity": "high"
    },
    {
      "id": "hipaa-phone-us",
      "name": "U.S. phone number (PHI context)",
      "regex": "\\b\\(?\\d{3}\\)?[-. ]?\\d{3}[-. ]?\\d{4}\\b",
      "severity": "medium"
    },
    {
      "id": "hipaa-email",
      "name": "Email address (PHI identifier)",
      "regex": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
      "severity": "medium"
    }
  ]
}
