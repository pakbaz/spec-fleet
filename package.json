{
  "name": "@pakbaz/specfleet",
  "version": "0.6.0",
  "description": "SpecFleet — a lean, thin Spec-Kit pipeline (specify · clarify · plan · tasks · analyze · implement · review · checklist) over GitHub Copilot CLI with cross-model review and a shared scratchpad MCP.",
  "type": "module",
  "bin": {
    "specfleet": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime/index.js"
  },
  "files": [
    "dist",
    "templates/.github",
    "templates/charters",
    "templates/mcp",
    "templates/skills",
    "templates/instruction.md",
    "templates/project.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"import('node:fs').then(({rmSync}) => rmSync('dist', { recursive: true, force: true }))\" && tsc -p tsconfig.json && node -e \"import('node:fs').then(({chmodSync}) => chmodSync('dist/cli.js', 0o755))\"",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e --testTimeout=180000",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "node ./dist/cli.js check",
    "verify:no-telemetry": "node scripts/check-no-telemetry.mjs",
    "version:sync": "node scripts/sync-docs-version.mjs",
    "version": "node scripts/sync-docs-version.mjs",
    "prepublishOnly": "npm run build && npm test && npm run verify:no-telemetry"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.1",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "license": "MIT",
  "author": "Sepehr Pakbaz",
  "homepage": "https://github.com/pakbaz/spec-fleet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pakbaz/spec-fleet.git"
  },
  "bugs": {
    "url": "https://github.com/pakbaz/spec-fleet/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "github",
    "copilot",
    "copilot-cli",
    "spec-kit",
    "spec-driven",
    "agents",
    "charters",
    "mcp",
    "cross-model-review",
    "scratchpad",
    "compliance",
    "governance",
    "alm"
  ]
}
